{% sw_extends '@Storefront/storefront/base.html.twig' %}

{% block base_head %}
    {{ parent() }}
    {% sw_include '@DesklyKnowledgeBase/storefront/page/kb-jsonld.html.twig' %}
{% endblock %}

{% block base_breadcrumb %}
    <div class="breadcrumb cms-breadcrumb container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb" itemscope itemtype="https://schema.org/BreadcrumbList">
                <li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                    <a href="{{ path('frontend.home.page') }}" itemprop="item">
                        <span itemprop="name">{{ "general.homeLink"|trans|striptags }}</span>
                    </a>
                    <meta itemprop="position" content="0">
                </li>
                <li class="breadcrumb-item active" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
                    <span itemprop="name">{{ "deskly-kb.breadcrumb.help"|trans }}</span>
                    <meta itemprop="position" content="1">
                </li>
            </ol>
        </nav>
    </div>
{% endblock %}

{% block base_content %}
    <div class="cms-page deskly-kb-overview">

        {# Sektion 1: Hero (weiss) #}
        <section class="deskly-kb-hero">
            <div class="container">
                <h1 class="deskly-kb-hero__title">
                    {{ "deskly-kb.overview.title"|trans }}
                </h1>
                <p class="deskly-kb-hero__subtitle">
                    {{ "deskly-kb.overview.subtitle"|trans }}
                </p>

                <div class="deskly-kb-search">
                    <form action="{{ path('frontend.kb.overview') }}" method="GET" class="deskly-kb-search-form">
                        <div class="input-group">
                            <input type="text"
                                   name="q"
                                   class="form-control"
                                   placeholder="{{ "deskly-kb.overview.search"|trans }}"
                                   value="{{ app.request.query.get('q', '') }}"
                                   aria-label="{{ "deskly-kb.overview.search"|trans }}">
                            <button type="submit" class="btn btn-primary">
                                {% sw_icon 'search' style { 'size': 'sm' } %}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </section>

        {# Sektion 2: Kategorien (hellgrau) #}
        {% if page.categories is not empty %}
            <section class="deskly-kb-categories">
                <div class="container">
                    <div class="deskly-kb-category-grid">
                        {% for category in page.categories %}
                            <article class="deskly-kb-category-card">
                                <a href="{{ path('frontend.kb.category', { categorySlug: category.slug }) }}"
                                   class="deskly-kb-category-card__link"
                                   title="{{ category.name }}">
                                    <h2 class="deskly-kb-category-card__title">{{ category.name }}</h2>

                                    {% if category.description %}
                                        <p class="deskly-kb-category-card__text">
                                            {{ category.description|striptags|u.truncate(150, '...') }}
                                        </p>
                                    {% endif %}

                                    <span class="deskly-kb-category-card__count">
                                        {{ "deskly-kb.overview.articlesCount"|trans({ '%count%': category.articles ? category.articles|length : 0 }) }}
                                    </span>
                                </a>
                            </article>
                        {% endfor %}
                    </div>
                </div>
            </section>
        {% else %}
            <div class="container">
                <div class="alert alert-info">
                    {{ "deskly-kb.overview.noCategories"|trans }}
                </div>
            </div>
        {% endif %}

    </div>
{% endblock %}
