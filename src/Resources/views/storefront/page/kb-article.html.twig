{% sw_extends '@Storefront/storefront/base.html.twig' %}

{% block base_head %}
    {{ parent() }}
    {% sw_include '@DesklyKnowledgeBase/storefront/page/kb-jsonld.html.twig' %}
{% endblock %}

{% block base_breadcrumb %}
    <div class="breadcrumb cms-breadcrumb container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb" itemscope itemtype="https://schema.org/BreadcrumbList">
                <li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                    <a href="{{ path('frontend.home.page') }}" itemprop="item">
                        <span itemprop="name">{{ "general.homeLink"|trans|striptags }}</span>
                    </a>
                    <meta itemprop="position" content="0">
                </li>
                <li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                    <a href="{{ path('frontend.kb.overview') }}" itemprop="item">
                        <span itemprop="name">{{ "deskly-kb.breadcrumb.help"|trans }}</span>
                    </a>
                    <meta itemprop="position" content="1">
                </li>
                <li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                    <a href="{{ path('frontend.kb.category', { categorySlug: page.category.slug }) }}" itemprop="item">
                        <span itemprop="name">{{ page.category.name }}</span>
                    </a>
                    <meta itemprop="position" content="2">
                </li>
                <li class="breadcrumb-item active" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
                    <span itemprop="name">{{ page.article.title }}</span>
                    <meta itemprop="position" content="3">
                </li>
            </ol>
        </nav>
    </div>
{% endblock %}

{% block base_content %}
    <div class="cms-page deskly-kb-article-page">
        <div class="container">

            <div class="row">

                {# Artikel-Content #}
                <div class="col-lg-9">
                    <article class="deskly-kb-article">
                        <header class="deskly-kb-article-header">
                            <h1>{{ page.article.title }}</h1>

                            {% if page.article.tags is not empty %}
                                <div class="deskly-kb-article-tags mb-3">
                                    {% for tag in page.article.tags %}
                                        <span class="badge bg-light text-dark">{{ tag }}</span>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </header>

                        <div class="deskly-kb-article-content">
                            {{ page.article.content|raw }}
                        </div>
                    </article>
                </div>

                {# Sidebar #}
                <aside class="col-lg-3">
                    <div class="deskly-kb-sidebar">
                        <a href="{{ path('frontend.kb.category', { categorySlug: page.category.slug }) }}"
                           class="btn btn-outline-secondary btn-sm w-100">
                            &larr; {{ "deskly-kb.article.backToCategory"|trans({ '%category%': page.category.name }) }}
                        </a>
                    </div>
                </aside>

            </div>

        </div>
    </div>
{% endblock %}
