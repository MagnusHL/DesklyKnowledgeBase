{% sw_extends '@Storefront/storefront/base.html.twig' %}

{% block base_head %}
    {{ parent() }}
    {% sw_include '@DesklyKnowledgeBase/storefront/page/kb-jsonld.html.twig' %}
{% endblock %}

{% block base_breadcrumb %}
    <div class="breadcrumb cms-breadcrumb container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb" itemscope itemtype="https://schema.org/BreadcrumbList">
                <li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                    <a href="{{ path('frontend.home.page') }}" itemprop="item">
                        <span itemprop="name">{{ "general.homeLink"|trans|striptags }}</span>
                    </a>
                    <meta itemprop="position" content="0">
                </li>
                <li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                    <a href="{{ path('frontend.kb.overview') }}" itemprop="item">
                        <span itemprop="name">{{ "deskly-kb.breadcrumb.help"|trans }}</span>
                    </a>
                    <meta itemprop="position" content="1">
                </li>
                <li class="breadcrumb-item active" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
                    <span itemprop="name">{{ page.category.name }}</span>
                    <meta itemprop="position" content="2">
                </li>
            </ol>
        </nav>
    </div>
{% endblock %}

{% block base_content %}
    <div class="cms-page deskly-kb-category-page">
        <div class="container">

            {# Kategorie-Header #}
            <header class="deskly-kb-category-header">
                <h1>{{ page.category.name }}</h1>

                {% if page.category.description %}
                    <div class="deskly-kb-category-description lead">
                        {{ page.category.description|raw }}
                    </div>
                {% endif %}
            </header>

            {# Zurück-Link #}
            <div class="deskly-kb-back-link mb-3">
                <a href="{{ path('frontend.kb.overview') }}" class="btn btn-outline-secondary btn-sm">
                    &larr; {{ "deskly-kb.category.backToOverview"|trans }}
                </a>
            </div>

            {# Artikel-Liste #}
            {% if page.articles is not empty %}
                <section class="deskly-kb-article-list">
                    {% for article in page.articles %}
                        <article class="deskly-kb-article-list-item card mb-3">
                            <a href="{{ path('frontend.kb.article', { categorySlug: page.category.slug, articleSlug: article.slug }) }}"
                               class="deskly-kb-article-list-link"
                               title="{{ article.title }}">
                                <div class="card-body">
                                    <h2 class="card-title h5">{{ article.title }}</h2>

                                    {% if article.shortText %}
                                        <p class="card-text text-muted">
                                            {{ article.shortText|striptags|u.truncate(200, '...') }}
                                        </p>
                                    {% endif %}

                                    {% if article.tags is not empty %}
                                        <div class="deskly-kb-article-tags">
                                            {% for tag in article.tags %}
                                                <span class="badge bg-light text-dark">{{ tag }}</span>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            </a>
                        </article>
                    {% endfor %}
                </section>
            {% else %}
                <div class="alert alert-info">
                    {{ "deskly-kb.category.noArticles"|trans }}
                </div>
            {% endif %}

        </div>
    </div>
{% endblock %}
